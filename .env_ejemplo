 # URL de tu instancia de Jira (sin https://)                                  
  JIRA_HOST=tu-empresa.atlassian.net                                          
                                                                                
  # Email de la cuenta de Jira con la que generaste el token
  JIRA_EMAIL=tu-email@empresa.com                                             
                                                                                
  # Token de API — generalo en:                                                 
  https://id.atlassian.com/manage-profile/security/api-tokens                   
  JIRA_TOKEN=tu-token-de-api                                                    
                                                                                
  # Puerto del servidor local                                                   
  PORT=8080                                                                     

