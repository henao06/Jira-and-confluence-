# ============================================================================
#  Configuracion del proxy.  Edita esto y volve a correr (./start.sh o tablet.sh).
#  No hay que tocar proxy.js nunca mas.
# ============================================================================

# Puerto donde ESCUCHA el proxy (lo que abris en la tablet / navegador).
PORT=8090

# Host que el proxy le dice a los backends (host-spoof).
#   'localhost' -> Moodle/Apache responden como si fuera acceso local (no redirige).
#   vacio (HOST_SPOOF=) -> reenvia el host original, sin mentir.
HOST_SPOOF=localhost

# Inyectar CORS en las respuestas (on / off).
CORS=on

# ----------------------------------------------------------------------------
#  RUTAS A EXPONER:   ROUTE <prefijo> <host:puerto>
#
#  - Se evaluan del prefijo MAS LARGO al mas corto (el mas especifico gana).
#  - "/" es el catch-all (todo lo que no matchee otra ruta).
#  - Agrega/quita lineas para exponer lo que quieras (una o VARIAS).
#
#  Ejemplos para OTROS proyectos:
#     ROUTE /api    127.0.0.1:3000
#     ROUTE /admin  127.0.0.1:4000
#     ROUTE /       127.0.0.1:5173
# ----------------------------------------------------------------------------

ROUTE /chatkit 127.0.0.1:8000
ROUTE /        127.0.0.1:80
